{
  "realm": "support",
  "enabled": true,
  "displayName": "SupportPlane - Operators",
  "loginTheme": "supportplane",
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "sslRequired": "external",
  "accessTokenLifespan": 3600,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "OPERATOR",
        "description": "Support operator with full access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "supportplane-frontend",
      "name": "SupportPlane Frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173"
      ],
      "protocolMappers": [
        {
          "name": "realm-role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "multivalued": "true",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "realm",
            "claim.value": "support",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "tenant_id-hardcoded",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "tenant_id",
            "claim.value": "support",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "supportplane-backend",
      "name": "SupportPlane Backend",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "directAccessGrantsEnabled": false,
      "protocolMappers": [
        {
          "name": "realm-role-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "roles",
            "multivalued": "true",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "tenant_id-hardcoded",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "tenant_id",
            "claim.value": "support",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "operator",
      "email": "operator@support.local",
      "firstName": "Support",
      "lastName": "Operator",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "operator1234",
          "temporary": false
        }
      ],
      "realmRoles": ["OPERATOR"]
    }
  ]
}
