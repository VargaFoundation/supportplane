# Copy to .env and customise. Loaded by docker-compose automatically.
#
# These variables are consumed by docker-compose.infra.yml (ClickHouse,
# Grafana, Pulsar) and docker-compose.yml (backend). Streaming is opt-in
# — leave PULSAR_ENABLED=false unless you want to test the streaming
# pipeline locally.

# ---------------------------------------------------------- ClickHouse
CLICKHOUSE_USER=supportplane
CLICKHOUSE_PASSWORD=change-me-in-dev

# ---------------------------------------------------------- Grafana
GRAFANA_ADMIN_PASSWORD=admin

# ---------------------------------------------------------- Pulsar (opt-in)
# Toggle the streaming pipeline for the backend.
PULSAR_ENABLED=false

# When PULSAR_ENABLED=true:
#   - Bring the infra stack up first:   docker-compose -f docker-compose.infra.yml up -d
#   - The pulsar-init sidecar will mint /pulsar/keys/superuser.token on the
#     pulsar-keys volume. Either copy it into a host file or shell into the
#     pulsar container to read it. Then put it here:
PULSAR_AUTH_TOKEN=
PULSAR_TLS_TRUST_CERTS=/pulsar/certs/ca.crt
PULSAR_SERVICE_URL=pulsar+ssl://supportplane-pulsar:6651
PULSAR_ADMIN_URL=https://supportplane-pulsar:8443
PULSAR_JWT_PRIVATE_KEY_PATH=/pulsar/keys/jwt-private.pem
